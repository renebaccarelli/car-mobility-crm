// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Usuários (Administrador / Vendedor) — 1:1 com auth.users do Supabase.
// O id é o mesmo uuid de auth.users.id; a linha é criada por um trigger
// (handle_new_user) no signup, não pelo Prisma.
// ---------------------------------------------------------------------------

enum TipoPerfil {
  ADMINISTRADOR
  VENDEDOR
  CONCESSIONARIA
}

model Usuario {
  id        String     @id @db.Uuid
  nome      String
  email     String     @unique
  username  String?    @unique
  telefone  String?
  perfil    TipoPerfil @default(VENDEDOR)
  ativo     Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Preenchido quando perfil = VENDEDOR: em qual unidade (concessionária +
  // marca) ele atua — é essa unidade que isola os dados dele.
  concessionariaMarcaId String?
  concessionariaMarca   ConcessionariaMarca? @relation("VendedorUnidade", fields: [concessionariaMarcaId], references: [id], onDelete: SetNull)

  // Preenchido quando perfil = CONCESSIONARIA: qual concessionária esse
  // login representa (enxerga todas as unidades/marcas dela).
  concessionariaId String?
  concessionaria   Concessionaria? @relation(fields: [concessionariaId], references: [id], onDelete: SetNull)

  clientesCadastrados Cliente[]        @relation("ClienteCadastradoPor")
  mensagens           Mensagem[]
  arquivosEnviados    ArquivoCliente[]
  lembretes           Lembrete[]

  @@map("usuarios")
}

// ---------------------------------------------------------------------------
// Concessionárias / marcas
// ---------------------------------------------------------------------------

model Marca {
  id        String   @id @default(cuid())
  nome      String   @unique
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())

  unidades ConcessionariaMarca[]

  @@map("marcas")
}

model Concessionaria {
  id        String   @id @default(cuid())
  nome      String
  telefone  String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuarios Usuario[]
  marcas   ConcessionariaMarca[]

  @@map("concessionarias")
}

// A "unidade autônoma": uma marca dentro de uma concessionária. É a essa
// unidade que o Vendedor é vinculado — não à Concessionaria diretamente —
// para que marcas diferentes da mesma concessionária fiquem isoladas.
model ConcessionariaMarca {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  concessionariaId String
  concessionaria   Concessionaria @relation(fields: [concessionariaId], references: [id], onDelete: Cascade)

  marcaId String
  marca   Marca @relation(fields: [marcaId], references: [id], onDelete: Restrict)

  vendedores Usuario[] @relation("VendedorUnidade")

  @@unique([concessionariaId, marcaId])
  @@map("concessionaria_marcas")
}

model Endereco {
  id          String  @id @default(cuid())
  logradouro  String?
  numero      String?
  complemento String?
  bairro      String?
  municipio   String?
  estado      String?
  cep         String?

  clienteId String?  @unique
  cliente   Cliente? @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@map("enderecos")
}

// ---------------------------------------------------------------------------
// Catálogo de serviços
// ---------------------------------------------------------------------------

enum CategoriaServico {
  RECOMENDADOS
  CNH
  LAUDOS
  ISENCOES
}

model Servico {
  id          String           @id @default(cuid())
  nome        String           @unique
  categoria   CategoriaServico
  valorPadrao Decimal          @db.Decimal(10, 2)
  descricao   String?
  ativo       Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  pedidoItens PedidoItem[]

  @@map("servicos")
}

enum MetodoPagamento {
  CREDITO
  BOLETO
  DEBITO
  TEF_DOC_TRANSFERENCIA_PIX
  NF_CONCESSIONARIA
  DINHEIRO
  DEPOSITO
  CHEQUE
}

// ---------------------------------------------------------------------------
// Cliente e pipeline do processo
// ---------------------------------------------------------------------------

enum EtapaProcesso {
  NAO_SE_APLICA
  INICIAL
  RELATORIO_MEDICO
  CNH_ESPECIAL
  LAUDO_RECEITA_FEDERAL
  RENOVACAO_CNH
  IPI
  ICMS
  PEDIDO_VEICULO
  FATURAMENTO
  LICENCIAMENTO
  IPVA
  RODIZIO
  CARTAO_DEFIS
  ENTREGA_VEICULO
}

enum PreferenciaContato {
  TELEFONE
  WHATSAPP
  EMAIL
}

model Cliente {
  id             String    @id @default(cuid())
  nome           String
  cpf            String?   @unique
  rg             String?
  cnh            String?
  dataNascimento DateTime?

  deficienciaMembrosInferiores Boolean?
  veiculoAcimaDe70Mil          Boolean?

  telefone           String?
  whatsapp           String?
  email              String?              @unique
  preferenciaContato PreferenciaContato?

  condutor    Boolean       @default(false)
  ativo       Boolean       @default(true)
  etapaAtual  EtapaProcesso @default(NAO_SE_APLICA)
  indicadoPor String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Vendedor dono do cadastro — usado pelas policies de RLS para isolamento.
  cadastradoPorId String  @db.Uuid
  cadastradoPor   Usuario @relation("ClienteCadastradoPor", fields: [cadastradoPorId], references: [id], onDelete: Restrict)

  // Preenchido no primeiro login do cliente no portal (link por e-mail).
  userId String? @unique @db.Uuid

  endereco              Endereco?
  condutoresAutorizados CondutorAutorizado[]
  pedidos               Pedido[]
  tarefas               Tarefa[]
  mensagens             Mensagem[]
  arquivos              ArquivoCliente[]
  lembretes             Lembrete[]

  @@map("clientes")
}

model CondutorAutorizado {
  id   String  @id @default(cuid())
  nome String
  cpf  String?
  cnh  String?

  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@map("condutores_autorizados")
}

// ---------------------------------------------------------------------------
// Vendas / pedidos
// ---------------------------------------------------------------------------

enum ResponsavelPagamento {
  CLIENTE
  EMPRESA
}

enum StatusServico {
  AGUARDANDO_CONFIRMACAO
  EM_ANDAMENTO
  CONCLUIDO
  CANCELADO
}

model Pedido {
  id        String   @id @default(cuid())
  numero    String   @unique @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  itens      PedidoItem[]
  pagamentos Pagamento[]

  @@map("pedidos")
}

model PedidoItem {
  id                   String               @id @default(cuid())
  valor                Decimal              @db.Decimal(10, 2)
  responsavelPagamento ResponsavelPagamento @default(CLIENTE)
  statusServico        StatusServico        @default(AGUARDANDO_CONFIRMACAO)
  pago                 Boolean              @default(false)

  pedidoId String
  pedido   Pedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  servicoId String
  servico   Servico @relation(fields: [servicoId], references: [id], onDelete: Restrict)

  @@map("pedido_itens")
}

model Pagamento {
  id     String           @id @default(cuid())
  valor  Decimal          @db.Decimal(10, 2)
  metodo MetodoPagamento?
  data   DateTime         @default(now())

  pedidoId String
  pedido   Pedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  @@map("pagamentos")
}

// ---------------------------------------------------------------------------
// Tarefas, timeline, arquivos, lembretes
// ---------------------------------------------------------------------------

enum StatusTarefa {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDA
}

model Tarefa {
  id          String       @id @default(cuid())
  titulo      String
  status      StatusTarefa @default(PENDENTE)
  iniciadoEm  DateTime?
  encerradoEm DateTime?
  createdAt   DateTime     @default(now())

  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@map("tarefas")
}

enum CategoriaMensagem {
  CADASTRO
  VENDAS
  GERAL
}

model Mensagem {
  id        String            @id @default(cuid())
  texto     String
  categoria CategoriaMensagem @default(GERAL)
  createdAt DateTime          @default(now())

  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  autorId String?  @db.Uuid
  autor   Usuario? @relation(fields: [autorId], references: [id], onDelete: SetNull)

  parentId  String?
  parent    Mensagem?  @relation("MensagemRespostas", fields: [parentId], references: [id], onDelete: Cascade)
  respostas Mensagem[] @relation("MensagemRespostas")

  @@map("mensagens")
}

model ArquivoCliente {
  id        String   @id @default(cuid())
  nome      String
  url       String
  createdAt DateTime @default(now())

  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  enviadoPorId String?  @db.Uuid
  enviadoPor   Usuario? @relation(fields: [enviadoPorId], references: [id], onDelete: SetNull)

  @@map("arquivos_cliente")
}

model DocumentoTemplate {
  id        String   @id @default(cuid())
  nome      String
  url       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("documento_templates")
}

model Lembrete {
  id        String   @id @default(cuid())
  texto     String
  data      DateTime
  publico   Boolean  @default(false)
  concluido Boolean  @default(false)
  createdAt DateTime @default(now())

  usuarioId String?  @db.Uuid
  usuario   Usuario? @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  @@map("lembretes")
}
